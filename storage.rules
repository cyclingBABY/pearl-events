rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && 
        (get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'editor' ||
         request.auth.token.email == "stuartdonsms@gmail.com");
    }
  }
}
